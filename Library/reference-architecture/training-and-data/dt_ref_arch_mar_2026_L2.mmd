C4Context
  title AI Data and Training Reference Architecture

  %% Users
  Person(dataEngineer, "Data Engineer", "A data engineer interacting with the catalog")
  Person(businessUser, "Business User", "A business user interacting with Data Presentation and BI Tools")
  Person(dataScientist, "Data Scientist", "A data scientist interacting with the Model Registry")

  Enterprise_Boundary(enterpriseDomain, "Enterprise Domain") {
    System_Boundary(dataDomain, "Data Domain") {  
      System_Boundary(dataPlatform, "Data Platform") {
        System_Boundary(dataOrchLayer, "Data Platform Orchestrator Layer") {
          Container(dataOrchInterface, "Data Platform Orchestrator Interface", "Component")
          Container(dataOrch, "Data Platform Orchestrator", "Component")
        }

        System_Boundary(dataCatalogLayer, "Data Catalog Layer") {
          Container(dataCatalogUI, "Data Catalog UI", "Component")
          Container(dataMetadata, "Metadata", "Data")
          Container(dataCrawlers, "Data Crawlers", "Component")
          Container(autoLabelers, "Auto Labelers", "Component")
        }
        
        System_Boundary(dataPresentationLayer, "Data Presentation Layer") {
          %% TODO: Should this be included in an AI architecture?
          Container(biTools, "BI and Visualization Tools", "Tool")
          Container(biReports, "BI Reports", "Tool")
        }

        System_Boundary(dataLandingLayer, "Data Landing Layer") {
          Container(dataLandingProxy, "Data Landing Proxy", "Storage")
          Container(rawData, "Raw Datasets", "Storage")
          Container(rawDataExp, "Raw Data Experiments", "Storage")
          System_Boundary(landingProcessingLayer, "Data Landing Processing Layer") {
            Container(dataIngestionPipeline, "Ingestion Pipeline", "Tool")
            Container(landingTransformationPipeline, "Data Transformation Pipelines", "Tool")
          }
        }

        System_Boundary(dataManagementLayer, "Data Management Layer") {
          Container(dataManagementProxy, "Data Management Proxy", "Storage")
          Container(vettedDatasets, "Vetted Datasets", "Storage")
          Container(dmzDataExp, "DMZ Data Experiments", "Storage")
          Container(processedData, "Processed Data", "Storage")
          Container(featureStore, "Feature Stores", "Storage")
          System_Boundary(managementProcessingLayer, "Data Management Processing Layer") {
            Container(managementTransformationPipeline, "Data Transformation Pipelines", "Tool")
            Container(dataValidationPipeline, "Data Validation Pipelines", "Tool")
          }
        }
      }

      System_Boundary(trainingPlatform, "Training Platform") {
        System_Boundary(trainOrchLayer, "Training Platform Orchestrator Layer") {
          Container(expTrackingSystem, "Experiment Tracking System", "Storage")
          Container(trainOrchAPI, "Training Platform Orchestrator API", "Component")
          Container(trainOrch, "Training Platform Orchestrator", "Component")
        }

        System_Boundary(modelRegistryLayer, "Model Registry Layer") {
          Container(modelRegistryUI, "Model Registry UI", "Interface")
          Container(modelMetadata, "Metadata", "Data")
          Container(unvettedModels, "Unvetted Models", "Storage")
          Container(vettedModels, "Vetted Models", "Storage")
        }

        System_Boundary(aiProcessingLayer, "AI Processing Layer") {
          Container(modelIngestionPipeline, "Ingestion Pipeline", "Tool")
          Container(modelTrainingPipeline, "Model Training Pipeline", "Tool")
          Container(modelEvaluationPipeline, "Model Evaluation Pipelines", "Tool")
          Container(hyperparameterStore, "Hyperparameter Store", "Storage")
        }
      }

      System_Boundary(observabilityLayer, "Observability Layer") {
        Container(logs, "Logs", "Data")
        Container(traces, "Traces", "Data")
        Container(metrics, "Metrics", "Data")
        Container(events, "Events", "Data")    
      }
      System_Boundary(attestationLayer, "Attestation and Lineage Layer") {
        Container(attestations, "Attestations", "Data")
      }
      System(streamingProcesses, "Streaming Processes", "Processes")
    }
    System(otherDomainDataSources, "Other Domain's Data Sources", "Internal Datasets")
  }

  %% External Systems
  System_Ext(thirdPartyModels, "3rd Party Models", "External Models")
  System_Ext(thirdPartyDataSources, "3rd Party Data Sources", "External Datasets")

