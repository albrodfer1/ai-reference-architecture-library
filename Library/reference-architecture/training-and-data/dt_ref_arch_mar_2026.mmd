C4Context
  title AI Data and Training Reference Architecture

  %% Users
  Person(dataeng, "Data Engineer", "A data engineer interacting with the catalog")
  Person(businessUser, "Business User", "An business user interacting with Data Presentation and BI Tools")
  Person(datasci, "Data Scientist", "An data scientist interacting with the Model Registry")

  Enterprise_Boundary(b0, "Enterprise Domain") {
    System_Boundary(b1, "Data Domain") {  
      System_Boundary(dataPlatform, "Data Platform") {
        System_Boundary(dataInterface, "Data Platform Orchestrator") {
          Container(dataOrchInterface, "Data Platform Orchestrator Interface", "Component")
          Container(dataOrch, "Data Platform Orchestrator", "Component")
        }

        System_Boundary(dataCatalog, "Data Catalog Layer") {
          Container(dataCatalogUI, "Data Catalog UI", "Component")
          Container(metadataData, "Metadata", "Data")
          Container(dataCrawlers, "Data Crawlers", "Component")
          Container(dataLabelers, "Auto Labelers", "Component")
        }
        
        System_Boundary(dataPresentation, "Data Presentation") {
          %% TODO: Should this be included in an AI architecture?
          Container(biTools, "BI and Visualization Tools", "Tool")
          Container(biReports, "BI Reports", "Tool")
        }

        System_Boundary(dataLanding, "Data Landing Layer") {
          Container(dataLandingProxy, "Data Landing Proxy", "Storage")
          Container(rawData, "Raw Datasets", "Storage")
          Container(rawDataExp, "Raw Data Experiments", "Storage")
          System_Boundary(dataLandingProcessing, "Data Landing Processing Layer") {
            Container(dataIngestionPipeline, "Ingestion Pipeline", "Tool")
            Container(dataLandingProcessing, "Data Transformation Pipelines", "Tool")
          }
        }

        System_Boundary(dataManagement, "Data Management Layer") {
          Container(dataManagementProxy, "Data Management Proxy", "Storage")
          Container(vettedDatasets, "Vetted Datasets", "Storage")
          Container(DMZExp, "DMZ Data Experiments", "Storage")
          Container(processedData, "Processed Data", "Storage")
          Container(featureStores, "Feature Stores", "Storage")
          System_Boundary(dataManagementProcessing, "Data Management Processing Layer") {
            Container(dataManagementProcessing, "Data Transformation Pipelines", "Tool")
            Container(dataValidationPipelines, "Data Validation Pipelines", "Tool")
          }
        }
      }

      System_Boundary(trainingLayer, "Training Platform") {
        System_Boundary(trainingInterface, "Training Platform Orchestrator") {
          Container(ExpTrackSystem, "Experiment Tracking System", "Storage")
          Container(trainOrchInterface, "Training Platform Orchestrator API", "Component")
          Container(trainOrch, "Training Platform Orchestrator", "Component")
        }

        System_Boundary(modelRegistry, "Model Registry Layer") {
          Container(modelRegistryUI, "Model Registry UI", "Interface")
          Container(metadataModel, "Metadata", "Data")
          Container(unvettedModels, "Unvetted Models", "Storage")
          Container(vettedModels, "Vetted Models", "Storage")
        }

        System_Boundary(AIProcessingLayer, "AI Processing Layer") {
          Container(modelIngestionPipeline, "Ingestion Pipeline", "Tool")
          Container(modelProcessing, "Model Training Pipeline", "Tool")
          Container(modelEvaluationPipeline, "Model Evaluations Pipelines", "Tool")
          Container(hyperParameterStore, "Hyperparameter Store", "Storage")
        }
      }

      System_Boundary(observabilityLayer, "Lineage and Observability") {
        Container(logs, "Logs", "Data")
        Container(traces, "Traces", "Data")
        Container(metrics, "Metrics", "Data")
        Container(events, "Events", "Data")    
      }
      System_Boundary(atestationLayer, "Attestation and Lineage Layer") {
        Container(attestations, "Attestations", "Data")
      }
      System(streamingProcesses, "Streaming Processes", "Processes")
    }
    System(otherDomainDataSources, "Other Domain's Data Sources", "Internal Datasets")
  }

  %% External Systems
  System_Ext(thirdPartyModels, "3rd Party Models", "External Models")
  System_Ext(thirdPartyDataSources, "3rd Party Data Sources", "External Datasets")

